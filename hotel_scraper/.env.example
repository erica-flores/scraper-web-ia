# --- LLM providers ---
# Gemini (Google AI Studio): https://aistudio.google.com/
GEMINI_API_KEY=

# Groq: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Cerebras: https://cloud.cerebras.ai/platform/api-keys
# Free tier tiene cap de 8k tokens de contexto — usar solo en chain "quick".
CEREBRAS_API_KEY=
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1

# OpenRouter (opcional): https://openrouter.ai/keys
# Si lo activás, descomentá un slot en llm/providers.yaml.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Cache ---
# Poné LLM_CACHE_ENABLED=false para desactivar el cache SQLite (útil en dev).
LLM_CACHE_ENABLED=true

# --- Scraper ---
SCRAPER_DELAY_MIN=1.5
SCRAPER_DELAY_MAX=4.0
MAX_CONCURRENT_IMAGES=5
SCRAPER_TIMEOUT=30
SCRAPER_MAX_RETRIES=3
